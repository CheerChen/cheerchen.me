flowchart LR
  client["Many clients\n~12,000 RPS"]
  apigw["Amazon API Gateway"]
  stageCache{{"1. Stage Cache\nGET only"}}
  lambda["AWS Lambda"]
  globals{{"2. Lambda globals\nhot-start cache + TTL"}}
  ecs["Amazon ECS\nApplication services"]
  valkey{{"3. ElastiCache for Valkey\napplication cache"}}
  rds["Amazon RDS\nAurora Serverless v2"]

  client --> apigw
  apigw --> stageCache
  stageCache -->|"cache hit"| client
  stageCache -->|"miss"| lambda
  lambda --> globals
  globals -->|"hit"| lambda
  globals -->|"miss / backend call"| ecs
  ecs --> valkey
  valkey -->|"hit"| ecs
  valkey -->|"miss"| rds
  rds --> ecs --> lambda --> apigw --> client